# Base URL of the PharmaSignal serving API (AWS HTTP API Gateway -> Lambda/FastAPI).
# Get it after deploying:  python infrastructure/api_deploy.py url --bucket <your-bucket>
# HTTP APIs use the $default stage, so there is NO /prod path segment.
# Leave unset to run the frontend on the bundled demo data.
NEXT_PUBLIC_PHARMASIGNAL_API_BASE_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com
